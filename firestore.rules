rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 1. User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && request.resource.data.keys().hasAll(['uid', 'email', 'displayName', 'isPremium', 'totalScans'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.isPremium == false; // Prevent self-upgrading on creation
      
      allow update: if isOwner(userId)
        && request.resource.data.uid == resource.data.uid
        && (
          // Action: Update Profile Info
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL'])) 
          || 
          // Action: Upgrade to Premium (In a real app, this should be server-side, but keeping it for MVP)
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isPremium']))
          ||
          // Action: Increment Scan Count
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalScans']))
        );
      
      // 2. Palm Reports
      match /reports/{reportId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId)
          && isValidId(reportId)
          && request.resource.data.keys().hasAll(['id', 'date', 'scores', 'insights', 'luckyTraits', 'timelinePredictions', 'createdAt'])
          && request.resource.data.id == reportId;
        
        allow update, delete: if false; // Reports are immutable for users
      }
    }
  }
}
